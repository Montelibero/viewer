:80 {
    root * /srv
    encode gzip

    # Reverse proxy to Stellar Expert API. Their Cloudflare returns 403 for
    # browser-origin requests, so we hop through Caddy with server-style headers.
    handle /api/expert/* {
        uri replace "/api/expert/" "/explorer/public/"
        reverse_proxy https://api.stellar.expert {
            header_up Host api.stellar.expert
            header_up -Origin
            header_up -Referer
            header_up User-Agent "Go-http-client/1.1"
            transport http {
                tls
                tls_server_name api.stellar.expert
            }
        }
    }

    handle {
        # Rewrite versioned paths (e.g. /v15/js/... or /v1.0.14/js/...) to actual paths (/js/...)
        @versioned {
            path_regexp v ^/v[^/]+/(.*)$
        }
        rewrite @versioned /{re.v.1}

        # Enable templates (Caddy will apply them if the file being served is supported, e.g. .html)
        templates

        # SPA Routing: Rewrite all requests that don't match a file to index.html
        try_files {path} /index.html

        file_server
    }
}
